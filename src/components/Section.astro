---
interface Props {
  id: string;
  num: string;
  title: string;
}
const { id, num, title } = Astro.props;
---

<section class="section" id={id} aria-labelledby={`${id}-title`}>
  <div class="container">
    <div class="section-header">
      <span class="section-number" aria-hidden="true">{num}</span>
      <h2 id={`${id}-title`}>{title}</h2>
    </div>
    <div class="prose">
      <slot />
    </div>
  </div>
</section>
