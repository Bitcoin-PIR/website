---
import Section from "~/components/Section.astro";
import Stage from "~/components/Stage.astro";

const cols = 4;
const rows = 4;
const targetCol = 2;
const targetRow = 1;
const cellW = 42;
const cellH = 26;
const gap = 6;
const gridX = 280;
const gridY = 140;
---

<Section id="onionpir-querypack" num="05" title="OnionPIR — one packed ciphertext">
  <p>
    We have the hypercube and the two ciphertext flavors. The last problem:
    if the client ships <em>N<sub>0</sub> + d − 1</em> selectors — 512 BFV
    ciphertexts for the initial dimension plus one RGSW per binary dim — at
    the standard parameters that's several megabytes per query. Too much.
  </p>
  <p>
    <strong>QueryPack</strong> solves it. The client writes every
    selection bit — <code>i<sub>0</sub></code> for the initial dim and every
    <code>b<sub>j</sub></code> for the remaining dims — into specific
    polynomial coefficients of a <em>single</em> BFV ciphertext, then sends
    that one ciphertext plus a short pseudorandom seed. The server
    runs <strong>QueryUnpack</strong> locally, applying a tree of
    substitution and RGSW-gadget operations, and recovers:
  </p>
  <ul>
    <li>
      A length-<code>N<sub>0</sub></code> vector of BFV ciphertexts, one
      per initial-dim slot, with <code>Enc(1)</code> at position
      <code>i<sub>0</sub></code> and <code>Enc(0)</code> elsewhere.
    </li>
    <li>
      One RGSW ciphertext per binary dimension, encrypting
      <code>b<sub>j</sub></code>.
    </li>
  </ul>
  <p>
    Net request size: about 16 KB at the standard parameters, regardless of
    database size. All the expansion work happens server-side where it
    costs nothing to ship.
  </p>

  <Stage
    caption="The single packed ciphertext unpacks into a BFV selector vector (initial dim) and RGSW bits. The hypercube then collapses one axis per ciphertext."
    label="QueryPack, unpack, and hypercube traversal"
  >
    <svg viewBox="0 0 680 380" role="img"
      aria-label="A single packed BFV ciphertext is unpacked server-side into a BFV vector and RGSW bits, then used to collapse the database hypercube dimension by dimension."
      data-anim="onion">

      <defs>
        <marker id="onion-arr" viewBox="0 0 6 6" refX="5" refY="3"
          markerWidth="6" markerHeight="6" orient="auto">
          <path d="M 0 0 L 6 3 L 0 6 z" fill="var(--fg-muted)"/>
        </marker>
      </defs>

      <g transform="translate(10,30)">
        <rect width="88" height="40" rx="7" class="svg-dim" stroke-width="1.5"/>
        <text x="44" y="18" text-anchor="middle" font-size="11" font-weight="600" fill="var(--fg)">Client</text>
        <text x="44" y="32" text-anchor="middle" class="svg-label" font-size="9">QueryPack</text>
      </g>

      <g transform="translate(108,42)" class="packed">
        <rect width="82" height="16" rx="3" fill="var(--link)" opacity="0.9" stroke="var(--link)"/>
        <text x="41" y="11" text-anchor="middle" font-size="9"
          font-family="ui-monospace, monospace" fill="#0a0b0f" font-weight="700">
          1 BFV ct
        </text>
      </g>
      <path class="packed" d="M 98 50 L 196 50" stroke="var(--fg-muted)" stroke-width="1"
        stroke-dasharray="3 3" fill="none" marker-end="url(#onion-arr)"/>

      <rect x="200" y="14" width="470" height="100" rx="8"
        class="svg-panel" stroke="var(--border)" fill="none"/>
      <text x="212" y="30" class="svg-label" font-weight="600">
        Server: QueryUnpack
      </text>

      <g transform="translate(212,46)" class="unpack-bfv">
        <text x="0" y="10" font-size="9" class="svg-label"
          fill="var(--accent)" font-weight="700">BFV vector — initial-dim selectors</text>
        {Array.from({ length: 4 }).map((_, i) => {
          const target = i === targetCol;
          return (
            <g transform={`translate(${i * 54},16)`}>
              <rect width="48" height="18" rx="3"
                fill="var(--accent)"
                opacity={target ? 0.9 : 0.3}/>
              <text x="24" y="13" text-anchor="middle" font-size="9"
                font-family="ui-monospace, monospace"
                font-weight={target ? 700 : 500}
                fill={target ? "#0a0b0f" : "var(--accent)"}>
                Enc({target ? "1" : "0"})
              </text>
            </g>
          );
        })}
      </g>

      <g transform="translate(456,46)" class="unpack-rgsw">
        <text x="0" y="10" font-size="9" class="svg-label" font-weight="700"
          fill="#e8a33c">RGSW bits — one per remaining dim</text>
        {[1, 2].map((k, i) => (
          <g transform={`translate(${i * 100},16)`}>
            <rect width="92" height="18" rx="3" fill="#e8a33c" opacity="0.85" stroke="#c98728"/>
            <text x="46" y="13" text-anchor="middle" font-size="9"
              font-family="ui-monospace, monospace" fill="#0a0b0f" font-weight="700">
              RGSW(b{k})
            </text>
          </g>
        ))}
      </g>

      <text x={gridX + cols * (cellW + gap) / 2 - gap / 2} y={gridY - 12}
        text-anchor="middle" class="svg-label" font-size="10">
        Database as 4 × 2 × 2 hypercube (flattened)
      </text>

      {Array.from({ length: rows }).map((_, r) =>
        Array.from({ length: cols }).map((__, c) => {
          const x = gridX + c * (cellW + gap);
          const y = gridY + r * (cellH + gap);
          const inCol = c === targetCol;
          const inHalf = r < 2;
          const isTarget = inCol && r === targetRow;
          const classes = [
            "cell",
            inCol ? "col-sel" : "",
            inCol && inHalf ? "half-sel" : "",
            isTarget ? "final" : "",
          ].filter(Boolean).join(" ");
          return (
            <g class={classes}>
              <rect x={x} y={y} width={cellW} height={cellH} rx="3"
                class="cell-rect" fill="var(--bg-elev-2)"
                stroke="var(--border-strong)" stroke-width="1"/>
              <text x={x + cellW / 2} y={y + cellH / 2 + 4}
                text-anchor="middle" font-size="9" class="svg-label"
                font-family="ui-monospace, monospace">
                {r * cols + c}
              </text>
            </g>
          );
        })
      )}

      <g transform={`translate(${gridX + cols * (cellW + gap) + 14},${gridY + 2})`}>
        <text y="0" class="phase phase-a" font-size="10" font-weight="700" fill="var(--accent)">
          ① BFV dot product
        </text>
        <text y="12" class="phase phase-a" font-size="9" fill="var(--fg-muted)">
          collapses dim 0
        </text>
        <text y="24" class="phase phase-a" font-size="9" fill="var(--fg-muted)">
          → 1 column
        </text>

        <text y="48" class="phase phase-b" font-size="10" font-weight="700" fill="#e8a33c">
          ② External product
        </text>
        <text y="60" class="phase phase-b" font-size="9" fill="var(--fg-muted)">
          RGSW(b₁): pick half
        </text>

        <text y="84" class="phase phase-c" font-size="10" font-weight="700" fill="#e8a33c">
          ③ External product
        </text>
        <text y="96" class="phase phase-c" font-size="9" fill="var(--fg-muted)">
          RGSW(b₂): pick half
        </text>

        <text y="120" class="phase phase-d" font-size="10" font-weight="700" fill="var(--ok)">
          ④ ModSwitch, send
        </text>
      </g>

      <g transform="translate(540,310)" class="out">
        <rect width="128" height="40" rx="6"
          fill="var(--ok)" opacity="0.18" stroke="var(--ok)"/>
        <text x="64" y="17" text-anchor="middle" font-size="11"
          font-family="ui-monospace, monospace" fill="var(--ok)" font-weight="700">
          Enc(entry 6)
        </text>
        <text x="64" y="31" text-anchor="middle" font-size="8"
          fill="var(--ok)">shrunk, → client</text>
      </g>
    </svg>
  </Stage>

  <h3 style="margin-top: 1.25rem;">The protocol in one read-through</h3>
  <ol>
    <li>
      <strong>Client:</strong> express <code>idx</code> as
      <code>(i<sub>0</sub>, b<sub>1</sub>, …, b<sub>d−1</sub>)</code>,
      QueryPack into one BFV ciphertext, send (~16 KB).
    </li>
    <li>
      <strong>Server — QueryUnpack:</strong> derive <em>N<sub>0</sub></em>
      BFV selectors plus <em>d − 1</em> RGSW ciphertexts.
    </li>
    <li>
      <strong>Server — initial dim:</strong> dot-product the BFV vector with
      the <code>N<sub>0</sub></code>-wide slab of the database. Collapses
      dim 0.
    </li>
    <li>
      <strong>Server — remaining dims:</strong> one external product per
      binary dim,  <code>x + RGSW(b<sub>j</sub>)·(y − x)</code>. Each step
      halves the remaining hypercube.
    </li>
    <li>
      <strong>Server — finish:</strong> one BFV ciphertext remains.
      Modulus-switch it from 60-bit to 27-bit coefficients to shrink the
      response, send (~13–57 KB depending on parameters).
    </li>
    <li><strong>Client:</strong> decrypt, read the row.</li>
  </ol>

  <h3>Numbers from the paper</h3>
  <p>
    From the
    <a href="https://eprint.iacr.org/2025/1142" rel="noopener">OnionPIR
    paper (ePrint 2025/1142)</a>, measured on a single core of an AWS
    <code>c5n.9xlarge</code> (Xeon 8124M @ 3.0 GHz), for a 1 GB database:
  </p>
  <ul>
    <li><strong>Request:</strong> ~16 KB (standard parameters).</li>
    <li>
      <strong>Response:</strong> 13.5–57 KB, giving a response blowup of
      ~2.5× the raw row size — vs ~100× for older compression-less PIR.
    </li>
    <li>
      <strong>Throughput:</strong> 1100–1600 MB/s server-side, close to
      memory bandwidth.
    </li>
    <li>
      <strong>Server storage:</strong> 0.63–2.9 MB of per-client key
      material (or send it with each request if the server prefers to be
      stateless).
    </li>
  </ul>

  <p>
    In BitcoinPIR, OnionPIR is one of three interchangeable backends. The
    rows it fetches are cuckoo bins, not raw records — the
    batch-code layer sits above whichever PIR backend is plugged in, so the
    same protocol shape works for DPF-PIR, OnionPIR, or HarmonyPIR.
  </p>
</Section>

<style>
  [data-anim="onion"] .packed,
  [data-anim="onion"] .unpack-bfv,
  [data-anim="onion"] .unpack-rgsw,
  [data-anim="onion"] .out,
  [data-anim="onion"] .phase {
    opacity: 0;
  }

  [data-anim="onion"].play .packed {
    animation: onion-in 0.4s var(--ease) 0.1s forwards;
  }
  [data-anim="onion"].play .unpack-bfv {
    animation: onion-in 0.4s var(--ease) 0.8s forwards;
  }
  [data-anim="onion"].play .unpack-rgsw {
    animation: onion-in 0.4s var(--ease) 1.2s forwards;
  }

  [data-anim="onion"] .cell { transition: opacity 0.4s; }

  [data-anim="onion"].play .cell:not(.col-sel) {
    animation: onion-dim 0.5s var(--ease) 2.0s forwards;
  }
  [data-anim="onion"].play .col-sel:not(.half-sel) {
    animation: onion-dim 0.5s var(--ease) 3.0s forwards;
  }
  [data-anim="onion"].play .half-sel:not(.final) {
    animation: onion-dim 0.5s var(--ease) 4.0s forwards;
  }
  [data-anim="onion"].play .final .cell-rect {
    animation: onion-glow 0.6s var(--ease) 4.4s forwards;
  }

  [data-anim="onion"].play .phase-a {
    animation: onion-in 0.4s var(--ease) 2.0s forwards;
  }
  [data-anim="onion"].play .phase-b {
    animation: onion-in 0.4s var(--ease) 3.0s forwards;
  }
  [data-anim="onion"].play .phase-c {
    animation: onion-in 0.4s var(--ease) 4.0s forwards;
  }
  [data-anim="onion"].play .phase-d {
    animation: onion-in 0.4s var(--ease) 4.6s forwards;
  }
  [data-anim="onion"].play .out {
    animation: onion-in 0.5s var(--ease) 4.6s forwards;
  }

  @keyframes onion-in { to { opacity: 1; } }
  @keyframes onion-dim { to { opacity: 0.15; } }
  @keyframes onion-glow { to { fill: var(--ok); } }

  @media (prefers-reduced-motion: reduce) {
    [data-anim="onion"] .packed,
    [data-anim="onion"] .unpack-bfv,
    [data-anim="onion"] .unpack-rgsw,
    [data-anim="onion"] .out,
    [data-anim="onion"] .phase { opacity: 1 !important; }
    [data-anim="onion"] .cell:not(.col-sel) { opacity: 0.15 !important; }
    [data-anim="onion"] .col-sel:not(.half-sel) { opacity: 0.15 !important; }
    [data-anim="onion"] .half-sel:not(.final) { opacity: 0.15 !important; }
    [data-anim="onion"] .final .cell-rect { fill: var(--ok) !important; }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-anim="onion"]').forEach((svg) => {
    const stage = svg.closest("[data-stage]");
    const run = () => {
      svg.classList.remove("play");
      void svg.getBoundingClientRect();
      svg.classList.add("play");
    };
    stage?.addEventListener("stage:visible", run);
    svg.addEventListener("click", run);
  });
</script>
